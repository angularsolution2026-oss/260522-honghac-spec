{
  "version": 8,
  "name": "HHC Day",
  "metadata": {
    "description": "Hồng Hạc City — light day theme. Uses OpenFreeMap Positron tiles."
  },
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "sprite": "https://demotiles.maplibre.org/sprite/sprite",
  "sources": {
    "osm-positron": {
      "type": "raster",
      "tiles": [
        "https://tile.openstreetmap.org/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "attribution": "© OpenStreetMap contributors",
      "maxzoom": 19
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f0ede8"
      }
    },
    {
      "id": "base-osm-raster",
      "type": "raster",
      "source": "osm-positron",
      "paint": {
        "raster-opacity": 0.85,
        "raster-saturation": -0.3,
        "raster-contrast": 0.1
      }
    }
  ]
}
