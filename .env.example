# =============================================================================
# HỒNG HẠC CITY — .env.example
# =============================================================================
# Copy to `.env.local` for local dev. Never commit `.env.local`.
# Production secrets live in Vercel Project → Settings → Environment Variables.
# All values below are SAFE PLACEHOLDERS — replace before any real deploy.
# =============================================================================

# -----------------------------------------------------------------------------
# CORE
# -----------------------------------------------------------------------------
# Public site URL — used by sitemap, canonical, OG, Resend reply-to.
NEXT_PUBLIC_SITE_URL="https://bacninhhonghaccity.vn"

# Node env (Next.js auto-sets in vercel builds; keep here for local).
NODE_ENV="development"

# Locale defaults
NEXT_PUBLIC_DEFAULT_LOCALE="vi"
NEXT_PUBLIC_SUPPORTED_LOCALES="vi,en"

# -----------------------------------------------------------------------------
# DATABASE — Postgres (Neon) for Payload CMS 3
# -----------------------------------------------------------------------------
# Pooled connection (used by Next.js runtime, edge functions, build).
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/hhc?sslmode=require"

# Direct connection (used by Payload migrations only).
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/hhc?sslmode=require"

# Payload CMS secret — long random string, used to sign JWT, encrypt cookies.
# Generate: `openssl rand -base64 48`
PAYLOAD_SECRET="REPLACE_WITH_64_CHAR_RANDOM_STRING_DO_NOT_USE_THIS_PLACEHOLDER"

# Payload server URL (where /admin is mounted — usually same as NEXT_PUBLIC_SITE_URL).
PAYLOAD_PUBLIC_SERVER_URL="https://bacninhhonghaccity.vn"

# -----------------------------------------------------------------------------
# FIRESTORE — lead capture, behavioral events, lot realtime sync
# -----------------------------------------------------------------------------
# Project ID (asia-southeast1 region recommended for VN latency + PDPL).
FIREBASE_PROJECT_ID="hhc-prod-001"

# Service account JSON (BASE64-encoded entire JSON file, paste single line).
# Generate: `base64 -w0 service-account.json`
# Server-side only. Never exposed to browser.
FIREBASE_SERVICE_ACCOUNT_B64="eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwicHJvamVjdF9pZCI6ICJoaGMtcHJvZC0wMDEiLCAuLi59"

# Public client config (safe in browser — Firestore security rules enforce auth).
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSyDFLmlL4_ePAkRTQO-RZgEsSwmrrN3XghU"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="moonlit-city-492317-k1.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="moonlit-city-492317-k1"
NEXT_PUBLIC_FIREBASE_APP_ID="1:63445387135:web:7d60fea5bd2eb566313c4a"

# -----------------------------------------------------------------------------
# MAPS — MapLibre GL + PMTiles
# -----------------------------------------------------------------------------
# CDN URL for the single-file PMTiles archive (~40MB, range-requested).
# In dev, points to `public/tiles/hhc.pmtiles`. In prod, point to Cloudflare R2.
NEXT_PUBLIC_PMTILES_URL="https://cdn.bacninhhonghaccity.vn/tiles/hhc.pmtiles"

# Optional fallback OSM context outside dev boundary.
NEXT_PUBLIC_OSM_TILES_URL="https://tiles.openfreemap.org/styles/liberty"

# Map style JSON URL (custom HHC style: day | dusk | aerial).
NEXT_PUBLIC_MAP_STYLE_DAY_URL="/styles/hhc-day.json"
NEXT_PUBLIC_MAP_STYLE_DUSK_URL="/styles/hhc-dusk.json"
NEXT_PUBLIC_MAP_STYLE_AERIAL_URL="/styles/hhc-aerial.json"

# -----------------------------------------------------------------------------
# CRM / LEAD ROUTING
# -----------------------------------------------------------------------------
# External CRM webhook receiving lead events (Salesforce / HubSpot / custom).
# Leave empty to skip CRM sync (Firestore + Telegram still work).
CRM_WEBHOOK_URL="https://crm.example.com/hooks/hhc/leads"
CRM_WEBHOOK_SECRET="REPLACE_WITH_HMAC_SHARED_SECRET"

# -----------------------------------------------------------------------------
# TELEGRAM ALERTS — hot/burning lead notifications
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN="0000000000:AAAA-bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"

# Chat IDs (negative for groups). Different chats per severity to control noise.
TELEGRAM_CHAT_ID_WARM_LEADS="-1001234567890"
TELEGRAM_CHAT_ID_HOT_LEADS="-1009876543210"
TELEGRAM_CHAT_ID_BURNING_LEADS="-1005555555555"
TELEGRAM_CHAT_ID_OPS_ERRORS="-1001111111111"

# -----------------------------------------------------------------------------
# EMAIL — Resend
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_REPLACE_WITH_REAL_KEY_starting_with_re_"

# Verified sender domain on Resend (must match SPF/DKIM).
EMAIL_FROM_LEAD_CONFIRM="Hồng Hạc City <chao@bacninhhonghaccity.vn>"
EMAIL_FROM_SALES_DIGEST="HHC System <noreply@bacninhhonghaccity.vn>"
EMAIL_REPLY_TO="tuvan@bacninhhonghaccity.vn"

# Recipients for sales digest.
EMAIL_SALES_DIGEST_TO="sales@bacninhhonghaccity.vn"
EMAIL_OPS_ALERTS_TO="ops@bacninhhonghaccity.vn"

# -----------------------------------------------------------------------------
# ANTI-BOT — Cloudflare Turnstile
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAAAAAA_REPLACE_WITH_REAL_KEY"
TURNSTILE_SECRET_KEY="0x4AAAAAAA_REPLACE_WITH_REAL_SECRET"

# Set true in test/CI to use Cloudflare-published test keys (always pass).
NEXT_PUBLIC_TURNSTILE_USE_TEST_KEYS="false"

# -----------------------------------------------------------------------------
# ANALYTICS
# -----------------------------------------------------------------------------
# GA4 Measurement ID — public, embedded in client bundle.
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# GTM container (optional; do not push PII).
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"

# Vercel Speed Insights is auto-enabled via dependency; no env needed.

# -----------------------------------------------------------------------------
# ERROR MONITORING — Sentry
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN="https://xxxxxxxxxxxxxx@o000000.ingest.sentry.io/0000000"
SENTRY_ORG="hong-hac-city"
SENTRY_PROJECT="web"
SENTRY_AUTH_TOKEN="sntrys_REPLACE_WITH_REAL_TOKEN_FOR_RELEASE_UPLOAD"

# -----------------------------------------------------------------------------
# STORAGE — Cloudflare R2 (or Vercel Blob)
# -----------------------------------------------------------------------------
# Media uploads (Payload CMS storage adapter).
R2_ACCOUNT_ID="0000000000000000000000000000000000"
R2_ACCESS_KEY_ID="REPLACE_WITH_R2_ACCESS_KEY"
R2_SECRET_ACCESS_KEY="REPLACE_WITH_R2_SECRET_KEY"
R2_BUCKET_MEDIA="hhc-media-prod"
R2_BUCKET_TILES="hhc-tiles-prod"
R2_PUBLIC_BASE_URL="https://cdn.bacninhhonghaccity.vn"

# -----------------------------------------------------------------------------
# REVALIDATION / WEBHOOKS
# -----------------------------------------------------------------------------
# Shared secret for /api/revalidate (called from Payload afterChange hooks).
REVALIDATE_SECRET="REPLACE_WITH_32_CHAR_RANDOM_STRING"

# Vercel API token + project ID for programmatic rollback in CI smoke fail.
VERCEL_API_TOKEN="REPLACE_WITH_VERCEL_TOKEN"
VERCEL_PROJECT_ID="prj_REPLACE_WITH_PROJECT_ID"
VERCEL_TEAM_ID="team_REPLACE_WITH_TEAM_ID"

# -----------------------------------------------------------------------------
# FEATURE FLAGS (Vercel Edge Config)
# -----------------------------------------------------------------------------
EDGE_CONFIG="https://edge-config.vercel.com/ecfg_REPLACE?token=REPLACE"

# Local override (JSON). Used when EDGE_CONFIG not set.
# Keys: ai_matching_v2, financial_v2, lifestyle_engine, comparison_hub
NEXT_PUBLIC_FEATURE_FLAGS_LOCAL='{"ai_matching_v2": false, "financial_v2": true}'

# -----------------------------------------------------------------------------
# PDPL / LEGAL
# -----------------------------------------------------------------------------
PDPL_POLICY_VERSION="v1.0-2026-05"
DPO_EMAIL="privacy@bacninhhonghaccity.vn"

# -----------------------------------------------------------------------------
# DEV / TEST HELPERS — never set in production
# -----------------------------------------------------------------------------
# When true, /api/leads/* skips Turnstile + writes to Firestore staging only.
DEV_SKIP_TURNSTILE="false"

# When true, /api/notify/telegram becomes no-op (logs only).
DEV_MUTE_TELEGRAM="false"

# Optional: bypass CDN for PMTiles locally.
DEV_PMTILES_LOCAL_PATH="public/tiles/hhc.pmtiles"
